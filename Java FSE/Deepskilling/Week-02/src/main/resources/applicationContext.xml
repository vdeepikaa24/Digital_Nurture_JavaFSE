<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <bean id="bookRepository"
          class="springcore_maven.exercise_2_implementing_dependency_injection.com.library.repository.BookRepository" />

    <bean id="bookService"
          class="springcore_maven.exercise_2_implementing_dependency_injection.com.library.service.BookService">
        <property name="bookRepository" ref="bookRepository" />
    </bean>

</beans>