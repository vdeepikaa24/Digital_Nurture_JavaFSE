server.port=8888
spring.application.name=config-server

# This activates the file system scanning mechanism for the server itself
spring.profiles.active=native
# NOTE: do not place `spring.profiles.active` in any service-specific property files

# Force the native scanner to look exclusively for specific service property files
spring.cloud.config.server.native.search-locations=file:///E:/Digital-Nurture-JavaFSE/Java FSE/Deepskilling/Week-04/Microservices with Spring Boot 3.0/exercise-2-inventory-discovery/config-repo/

# IMPORTANT: Do not propagate spring.profiles.active from the config server to clients.
# Spring Boot fails if `spring.profiles.active` appears in imported config.
spring.config.use-legacy-processing=false

