<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Individual Country Beans -->
    <bean id="in" class="com.cognizant.spring_learn.model.Country">
        <constructor-arg value="IN" />
        <constructor-arg value="India" />
    </bean>
    
    <bean id="us" class="com.cognizant.spring_learn.model.Country">
        <constructor-arg value="US" />
        <constructor-arg value="United States" />
    </bean>
    
    <bean id="jp" class="com.cognizant.spring_learn.model.Country">
        <constructor-arg value="JP" />
        <constructor-arg value="Japan" />
    </bean>
    
    <bean id="de" class="com.cognizant.spring_learn.model.Country">
        <constructor-arg value="DE" />
        <constructor-arg value="Germany" />
    </bean>

    <!-- List of countries -->
    <bean id="countryList" class="java.util.ArrayList">
        <constructor-arg>
            <list>
                <ref bean="in" />
                <ref bean="us" />
                <ref bean="jp" />
                <ref bean="de" />
            </list>
        </constructor-arg>
    </bean>
</beans>