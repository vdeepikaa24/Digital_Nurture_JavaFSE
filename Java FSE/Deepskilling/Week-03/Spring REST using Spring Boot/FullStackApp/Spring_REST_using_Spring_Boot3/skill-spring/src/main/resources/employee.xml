<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans 
       http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- Define Department beans -->
    <bean id="dept1" class="com.cognizant.skill_spring.model.Department">
        <property name="id" value="1"/>
        <property name="name" value="IT"/>
    </bean>
    <bean id="dept2" class="com.cognizant.skill_spring.model.Department">
        <property name="id" value="2"/>
        <property name="name" value="HR"/>
    </bean>

    <!-- Define Employee instances using ref to link to Department beans -->
    <bean id="emp1" class="com.cognizant.skill_spring.model.Employee">
        <property name="id" value="1"/>
        <property name="name" value="Deepikaa"/>
        <property name="department" ref="dept1"/>
    </bean>
    <bean id="emp2" class="com.cognizant.skill_spring.model.Employee">
        <property name="id" value="2"/>
        <property name="name" value="Dharshini"/>
        <property name="department" ref="dept2"/>
    </bean>
    <bean id="emp3" class="com.cognizant.skill_spring.model.Employee">
        <property name="id" value="3"/>
        <property name="name" value="Dhaarani"/>
        <property name="department" ref="dept1"/>
    </bean>
    <bean id="emp4" class="com.cognizant.skill_spring.model.Employee">
        <property name="id" value="4"/>
        <property name="name" value="Dhivyadharshini"/>
        <property name="department" ref="dept2"/>
    </bean>

    <!-- Define Employee List -->
    <bean id="employeeList" class="java.util.ArrayList">
        <constructor-arg>
            <list>
                <ref bean="emp1"/>
                <ref bean="emp2"/>
                <ref bean="emp3"/>
                <ref bean="emp4"/>
            </list>
        </constructor-arg>
    </bean>

    <!-- Define Department List -->
    <bean id="departmentList" class="java.util.ArrayList">
        <constructor-arg>
            <list>
                <ref bean="dept1"/>
                <ref bean="dept2"/>
            </list>
        </constructor-arg>
    </bean>

</beans>